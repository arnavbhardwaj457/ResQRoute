# ─────────────────────────────────────────────
# ResQRoute Web — Environment Variables
# ─────────────────────────────────────────────

# API (backend URL)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Maps — ResQRoute uses FREE OpenStreetMap + OSRM routing.
# No API key required! 🎉
# The following is optional if you want a custom OSRM server:
# NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org
